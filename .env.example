# Atlantis — variáveis de ambiente. Copie para `.env.local` e preencha.
# `.env.local` é gitignored (NÃO commitar segredos).

# --- Supabase ---
# Públicas (vão ao browser, protegidas por RLS):
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Secreta (BYPASSA a RLS) — só no servidor (src/pages/api/* e SSR). NUNCA no cliente:
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- Geração de imagem (opcional; usada nos uploads/illustração) ---
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
